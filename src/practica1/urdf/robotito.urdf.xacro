<?xml version="1.0"?>
<robot name="robotito" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- namespace -->
  <xacro:arg name="prefix" default="" />
  <xacro:property name="prefijo_ns" value="$(arg prefix)" />

  <!-- los distintos archivos que usa -->
  <xacro:include filename="inertial_macros.xacro" />
  <xacro:include filename="gazebo_control.xacro" />
  <xacro:include filename="lidar.xacro" />
  <xacro:include filename="camera.xacro" />

  <!-- ya las cosas del robot -->
  <xacro:property name="largo_chasis" value="0.4" />
  <xacro:property name="ancho_chasis" value="0.3" />
  <xacro:property name="alto_chasis" value="0.1" />
  <xacro:property name="masa_chasis" value="1.0" />

  <xacro:property name="radio_rueda" value="0.1" />
  <xacro:property name="grosor_rueda" value="0.04" />
  <xacro:property name="masa_rueda" value="0.1" />
  <xacro:property name="offset_rueda_x" value="0.1" />
  <xacro:property name="offset_rueda_y" value="0.1705" />
  <xacro:property name="offset_rueda_z" value="0.0" />


  <xacro:property name="radio_rueda_loca" value="0.025" />
  <xacro:property name="masa_rueda_loca" value="0.05" />
  <xacro:property name="offset_rueda_loca_x" value="0.15" />
  <xacro:property name="offset_rueda_loca_z" value="-0.075" />

  <material name="white">
    <color rgba="1 1 1 1" />
  </material>

  <material name="orange">
    <color rgba="1 0.3 0.1 1"/>
  </material>

  <material name="blue">
    <color rgba="0.2 0.2 1 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>


  <!-- el base link-->
  <link name="${prefijo_ns}base_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="${largo_chasis} ${ancho_chasis} ${alto_chasis}"/>
        </geometry>
        <material name="green"/>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="${largo_chasis} ${ancho_chasis} ${alto_chasis}"/>
        </geometry>
    </collision>
    <xacro:inercia_caja mass="${masa_chasis}" x="${largo_chasis}" y="${ancho_chasis}" z="${alto_chasis}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inercia_caja>
  </link>


  <!-- wheel macro -->
  <xacro:macro name="wheel" params="lado desplazamiento_y">
    <link name="${prefijo_ns}${lado}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="1.5707 0 0 "/>
        <geometry>
            <cylinder radius="${radio_rueda}" length="${grosor_rueda}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5707 0 0 "/>
        <geometry>
            <cylinder radius="${radio_rueda}" length="${grosor_rueda}"/>
        </geometry>
      </collision>
      <xacro:inercia_cilindro mass="${masa_rueda}" length="${grosor_rueda}" radius="${radio_rueda}">
        <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      </xacro:inercia_cilindro>
    </link>

    <joint name="${prefijo_ns}${lado}_wheel_joint" type="continuous">
      <parent link="${prefijo_ns}base_link"/>
      <child link="${prefijo_ns}${lado}_wheel"/>
      <origin xyz="${-offset_rueda_x} ${desplazamiento_y} ${offset_rueda_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel lado="left" desplazamiento_y="${offset_rueda_y}"/>
  <xacro:wheel lado="right" desplazamiento_y="${-offset_rueda_y}"/>


<!-- rueda caster-->

  <link name="${prefijo_ns}caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${radio_rueda_loca}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${radio_rueda_loca}"/>
      </geometry>
    </collision>
    <xacro:inercia_esfera mass="${masa_rueda_loca}" radius="${radio_rueda_loca}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inercia_esfera>
  </link>

  <joint name="${prefijo_ns}caster_joint" type="fixed">
    <parent link="${prefijo_ns}base_link"/>
    <child link="${prefijo_ns}caster_wheel"/>
    <origin xyz="${offset_rueda_loca_x} 0 ${offset_rueda_loca_z}"/>
  </joint>

</robot>